{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node copy-android-icons.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "npx -y copyfiles -u 3 node_modules/sql.js/dist/sql-wasm.wasm public/assets/ && node -e \"import('fs').then(fs => { fs.copyFileSync('src/assets/images/KhayyatProLogo (3).png', 'public/favicon.png'); fs.copyFileSync('src/assets/images/KhayyatProLogo (3).png', 'public/logo.png'); })\" && node copy-android-icons.cjs"
  },
