    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react-signature-canvas": "^1.0.7",
